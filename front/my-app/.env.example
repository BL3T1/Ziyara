# Local dev: defaults to company dashboard if unset (override here, or use surface scripts below)
# VITE_APP_SURFACE=company
# VITE_APP_SURFACE=provider
# VITE_APP_SURFACE=landing

VITE_API_URL=/api/v1

# Surface-specific dev scripts (port mirrors Docker portmode):
#   npm run dev:landing   → http://localhost:7070  (uses .env.landing)
#   npm run dev:company   → http://localhost:7050  (uses .env.company)
#   npm run dev:provider  → http://localhost:7060  (uses .env.provider)
#   npm run dev           → http://localhost:5173  (uses .env, defaults to company)

# Landing bundle only: absolute bases for sign-in CTAs (Docker build args in compose)
# VITE_COMPANY_APP_URL=https://app.example.com
# VITE_PROVIDER_APP_URL=https://partners.example.com
# VITE_LANDING_APP_URL=https://www.example.com  ← used by dashboard footer Privacy/Terms/Contact links
