# Copy to ".env" in this directory (docker compose loads it automatically).
# Required for: postgres, backend, pgadmin.

# Avoid ! and $ in passwords (Windows / Compose .env parsing).
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-at-least-64-characters-for-jwt-hmac-signing-key-material
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-login

# Optional (compose default shown)
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# APP_DEMO_PASSWORD=Demo123!
