# ============================================================
# ZIYARA — Environment Configuration
# Copy to .env (gitignored). Docker Compose reads it automatically.
# Avoid ! and $ in values — they break Windows/Compose .env parsing.
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=change-me-strong-password

# Minimum 64 characters. Generate: openssl rand -hex 48
JWT_SECRET=change-me-at-least-64-chars-for-hmac-signing-key-here

# pgAdmin web UI login password
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin

# ── REQUIRED IN PRODUCTION ───────────────────────────────────
# AES-256 key for PII field encryption (MFA secrets, sensitive data).
# Generate: openssl rand -base64 32
# ZIYARA_PII_ENCRYPTION_KEY_BASE64=

# Webhook signature secret — required when PAYMENT_GATEWAY_PROVIDER != stub.
# Generate: openssl rand -hex 32
# PAYMENT_WEBHOOK_SECRET=

# ── JWT Tokens ───────────────────────────────────────────────
# JWT_EXPIRATION=86400000           # access token TTL ms  (default 24 h)
# JWT_REFRESH_EXPIRATION=604800000  # refresh token TTL ms (default 7 d)
# JWT_COOKIE_SECURE=true            # set true in production (HTTPS only)

# ── Security ─────────────────────────────────────────────────
# Enable Postgres row-level security (multi-tenant data isolation)
# ZIYARA_RLS_ENABLED=true

# Enable HTTP Strict Transport Security header
# ZIYARA_SECURITY_HSTS_ENABLED=true

# Comma-separated UserRole names that must have TOTP enrolled before login.
# Leave EMPTY in dev — otherwise seeded admin accounts will be locked out.
# ZIYARA_SECURITY_MFA_REQUIRED_ROLES=SUPER_ADMIN,CEO,FINANCE_MANAGER,GENERAL_MANAGER

# Password strength score: 0=off, 2=docker default, 3=recommended prod, 4=strict
# ZIYARA_PASSWORD_MIN_ZXCVBN_SCORE=3

# Comma-separated allowed CORS origins (empty = localhost defaults in dev)
# ZIYARA_CORS_ALLOWED_ORIGINS=https://app.example.com,https://partners.example.com

# ── Redis (distributed JWT blocklist + login rate-limiting) ──
# SPRING_DATA_REDIS_HOST=redis
# SPRING_DATA_REDIS_PORT=6379
# ZIYARA_RATE_LIMIT_LOGIN_REDIS_ENABLED=true

# ── Payment Gateway ──────────────────────────────────────────
# PAYMENT_GATEWAY_PROVIDER=stripe    # stub (default) | stripe
# PAYMENT_GATEWAY_ENABLED=true
# PAYMENT_GATEWAY_API_KEY=sk_live_...
# PAYMENT_GATEWAY_BASE_URL=https://api.stripe.com

# ── Media Storage ────────────────────────────────────────────
# APP_MEDIA_STORAGE_BACKEND=s3       # local (default) | s3
# APP_MEDIA_S3_BUCKET=ziyara-media
# APP_MEDIA_S3_REGION=us-east-1
# APP_MEDIA_PUBLIC_BASE_URL=https://cdn.example.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── FX Rate Auto-refresh ─────────────────────────────────────
# ZIYARA_FX_REFRESH_ENABLED=true
# ZIYARA_FX_REFRESH_CRON=0 0 6 * * *         # daily 06:00 UTC
# ZIYARA_FX_REFRESH_API_KEY=                 # exchangerate.host API key
# ZIYARA_FX_REFRESH_BASE_CURRENCY=USD
# ZIYARA_FX_REFRESH_TARGET_CURRENCIES=EUR,SAR,GBP,AED

# ── Reporting ────────────────────────────────────────────────
# ZIYARA_REPORTING_MV_REFRESH_ENABLED=true
# ZIYARA_REPORTING_MV_CRON=0 20 2 * * *

# ── Data Retention ───────────────────────────────────────────
# ZIYARA_DATA_RETENTION_ENABLED=true

# ── Observability ────────────────────────────────────────────
# Actuator management port (separate from 8080 so it stays off the public ingress)
# MANAGEMENT_PORT=8081
# MANAGEMENT_OTLP_TRACING_ENDPOINT=http://otel-collector:4318/v1/traces
# MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.05

# ── Kafka Staff Notifications ────────────────────────────────
# ZIYARA_NOTIFICATIONS_KAFKA_ENABLED=true

# ── pgAdmin ──────────────────────────────────────────────────
# PGADMIN_DEFAULT_EMAIL=admin@example.com

# ── Demo Accounts ────────────────────────────────────────────
# APP_DEMO_PASSWORD=Demo123!

# ══════════════════════════════════════════════════════════════
# IP MODE — docker compose --profile ipmode up -d --build
#
# A single gateway nginx container terminates TLS on all public
# ports. Backend and frontend containers are internal only.
#
# BEFORE FIRST RUN:
#   1. cd infra/certs && sh generate.sh   # creates server.crt / server.key / ca.crt
#   2. cp infra/certs/ca.crt \
#        SYRIA-TOURISM-APP-main/SYRIA-TOURISM-APP-main/android/app/src/main/res/raw/ziyara_ca.crt
#   3. Uncomment and fill ALL lines below, then: cp .env.example .env
#
# Architecture:
#   BIND_IP:9000 HTTPS  →  gateway  →  backend:8080
#   BIND_IP:7050 HTTPS  →  gateway  →  company-ipmode:80
#   BIND_IP:7060 HTTPS  →  gateway  →  provider-ipmode:80
#   BIND_IP:7070 HTTPS  →  gateway  →  landing-ipmode:80
#   BIND_IP:7075 HTTP   →  gateway  →  pgadmin:80
# ══════════════════════════════════════════════════════════════

# Server LAN IP (the machine running Docker)
# BIND_IP=10.45.30.145

# Gateway API port
# BACKEND_PORT=9000

# Keep backend and pgAdmin off the LAN — gateway is the only public entry point
# BACKEND_BIND_IP=127.0.0.1
# PGADMIN_BIND_IP=127.0.0.1

# Frontend surface ports (all served by gateway with TLS)
# COMPANY_PORT=7050   →  https://10.45.30.145:7050  (Company dashboard)
# PROVIDER_PORT=7060  →  https://10.45.30.145:7060  (Provider portal)
# LANDING_PORT=7070   →  https://10.45.30.145:7070  (Landing / booking)
# PGADMIN_PORT=7075   →  http://10.45.30.145:7075   (pgAdmin DB UI — HTTP only)

# Full base URL baked into frontend bundles at build time — must be HTTPS
# API_EXTERNAL_URL=https://10.45.30.145:9000/api/v1

# CORS: allow all three HTTPS frontend origins to call the API
# ZIYARA_CORS_ALLOWED_ORIGINS=https://10.45.30.145:7050,https://10.45.30.145:7060,https://10.45.30.145:7070

# Landing page "sign in" CTA links (override only if ports/IP differ from above)
# COMPANY_URL=https://10.45.30.145:7050
# PROVIDER_URL=https://10.45.30.145:7060
