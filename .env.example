# ============================================================
# ZIYARA — Environment Configuration
# Copy to .env (gitignored). Docker Compose reads it automatically.
# Avoid ! and $ in values — they break Windows/Compose .env parsing.
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=change-me-strong-password

# Minimum 64 characters. Generate: openssl rand -hex 48
JWT_SECRET=change-me-at-least-64-chars-for-hmac-signing-key-here

# pgAdmin web UI login password
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin

# ── REQUIRED IN PRODUCTION ───────────────────────────────────
# AES-256 key for PII field encryption (MFA secrets, sensitive data).
# REQUIRED — production will refuse to start without this (PiiEncryptionStartupGuard).
# Generate: openssl rand -base64 32
ZIYARA_PII_ENCRYPTION_KEY_BASE64=change-me-generate-with-openssl-rand-base64-32

# Webhook signature secret — required when PAYMENT_GATEWAY_PROVIDER != stub.
# Generate: openssl rand -hex 32
# PAYMENT_WEBHOOK_SECRET=

# ── JWT Tokens ───────────────────────────────────────────────
# JWT_EXPIRATION=86400000           # access token TTL ms  (default 24 h)
# JWT_REFRESH_EXPIRATION=604800000  # refresh token TTL ms (default 7 d)
# JWT_COOKIE_SECURE=true            # set true in production (HTTPS only)

# ── Security ─────────────────────────────────────────────────
# Enable Postgres row-level security (multi-tenant data isolation)
# ZIYARA_RLS_ENABLED=true

# Enable HTTP Strict Transport Security header
# ZIYARA_SECURITY_HSTS_ENABLED=true

# Comma-separated UserRole names that must have TOTP enrolled before login.
# Leave EMPTY in dev — otherwise seeded admin accounts will be locked out.
# ZIYARA_SECURITY_MFA_REQUIRED_ROLES=SUPER_ADMIN,CEO,FINANCE_MANAGER,GENERAL_MANAGER

# Password strength score: 0=off, 2=docker default, 3=recommended prod, 4=strict
# ZIYARA_PASSWORD_MIN_ZXCVBN_SCORE=3

# Comma-separated allowed CORS origins (empty = localhost defaults in dev)
# ZIYARA_CORS_ALLOWED_ORIGINS=https://app.example.com,https://partners.example.com

# ── Redis (distributed JWT blocklist + login rate-limiting) ──
# SPRING_DATA_REDIS_HOST=redis
# SPRING_DATA_REDIS_PORT=6379
# ZIYARA_RATE_LIMIT_LOGIN_REDIS_ENABLED=true

# ── Payment Gateway ──────────────────────────────────────────
# PAYMENT_GATEWAY_PROVIDER=stripe    # stub (default) | stripe
# PAYMENT_GATEWAY_ENABLED=true
# PAYMENT_GATEWAY_API_KEY=sk_live_...
# PAYMENT_GATEWAY_BASE_URL=https://api.stripe.com

# ── Media Storage ────────────────────────────────────────────
# APP_MEDIA_STORAGE_BACKEND=s3       # local (default) | s3
# APP_MEDIA_S3_BUCKET=ziyara-media
# APP_MEDIA_S3_REGION=us-east-1
# APP_MEDIA_PUBLIC_BASE_URL=https://cdn.example.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── FX Rate Auto-refresh ─────────────────────────────────────
# ZIYARA_FX_REFRESH_ENABLED=true
# ZIYARA_FX_REFRESH_CRON=0 0 6 * * *         # daily 06:00 UTC
# ZIYARA_FX_REFRESH_API_KEY=                 # exchangerate.host API key
# ZIYARA_FX_REFRESH_BASE_CURRENCY=USD
# ZIYARA_FX_REFRESH_TARGET_CURRENCIES=EUR,SAR,GBP,AED

# ── Reporting ────────────────────────────────────────────────
# Enable nightly CONCURRENT refresh of mv_pay_daily_totals (V12 migration).
# The unique index ux_mv_pay_daily_totals is required and exists after V12.
# Safe to enable once the database is in steady-state (not a fresh install still
# running seed migrations). Cron default: 02:20 UTC daily.
ZIYARA_REPORTING_MV_REFRESH_ENABLED=true
# ZIYARA_REPORTING_MV_CRON=0 20 2 * * *

# ── Data Retention ───────────────────────────────────────────
# ZIYARA_DATA_RETENTION_ENABLED=true

# ── Observability ────────────────────────────────────────────
# Actuator management port (separate from 8080 so it stays off the public ingress)
# MANAGEMENT_PORT=8081
# MANAGEMENT_OTLP_TRACING_ENDPOINT=http://otel-collector:4318/v1/traces
# MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.05

# ── Kafka Staff Notifications ────────────────────────────────
# ZIYARA_NOTIFICATIONS_KAFKA_ENABLED=true

# ── pgAdmin ──────────────────────────────────────────────────
# PGADMIN_DEFAULT_EMAIL=admin@example.com

# ── Demo Accounts ────────────────────────────────────────────
# APP_DEMO_PASSWORD=Demo123!

# ══════════════════════════════════════════════════════════════
# PORT MODE — docker compose --profile portmode up -d --build
#
# No TLS, no /etc/hosts, no cert setup. Works from localhost
# or any LAN IP. Recommended for local development.
#
# Default (localhost only — no changes needed):
#   http://localhost:7050  Company dashboard
#   http://localhost:7060  Provider portal
#   http://localhost:7070  Landing page
#   http://localhost:8080  API
#
# LAN access (e.g. from another machine on 10.x / 192.168.x):
#   1. Set PORTMODE_HOST to this machine's IP
#   2. Rebuild: docker compose --profile portmode up -d --build
#   3. Access via http://10.45.30.145:7050 etc.
# ══════════════════════════════════════════════════════════════

# LAN IP of the machine running Docker — used by the landing page
# CTA links so "Sign in" / "Partner portal" buttons point to the right host.
# Leave unset for localhost-only access (default).
# PORTMODE_HOST=10.45.30.145

# Override ports if defaults conflict with existing services
# COMPANY_PORT=7050
# PROVIDER_PORT=7060
# LANDING_PORT=7070

# ══════════════════════════════════════════════════════════════
# IP MODE — docker compose --profile ipmode up -d --build
#
# A single gateway nginx container terminates TLS on all public
# ports. Backend, frontend, and monitoring containers are internal only.
# pgAdmin is NOT exposed through the gateway — see SSH tunnel note below.
#
# BEFORE FIRST RUN:
#   1. cd infra/certs && BIND_IP=<server-ip> sh generate.sh
#      # creates server.crt / server.key / ca.crt
#   2. cp infra/certs/ca.crt \
#        SYRIA-TOURISM-APP-main/SYRIA-TOURISM-APP-main/android/app/src/main/res/raw/ziyara_ca.crt
#   3. Uncomment and fill ALL lines below, then: cp .env.example .env
#
# Architecture:
#   BIND_IP:7005 HTTPS  →  gateway  →  backend:8080       (REST API + STOMP WS)
#   BIND_IP:7050 HTTPS  →  gateway  →  company-ipmode:80  (Company dashboard)
#   BIND_IP:7060 HTTPS  →  gateway  →  provider-ipmode:80 (Provider portal)
#   BIND_IP:7070 HTTPS  →  gateway  →  landing-ipmode:80  (Landing / booking)
#   BIND_IP:7083 HTTPS  →  gateway  →  prometheus:9090    (Prometheus UI)
#   BIND_IP:7085 HTTPS  →  gateway  →  grafana:3000       (Grafana dashboards)
#   pgAdmin: SSH tunnel only → ssh -L 7065:127.0.0.1:7065 user@server → http://localhost:7065
# ══════════════════════════════════════════════════════════════

# Server LAN/public IP (the machine running Docker)
# BIND_IP=10.45.30.145

# Keep backend off the public network — gateway is the only entry point
# BACKEND_BIND_IP=127.0.0.1

# Frontend surface ports (all served by gateway with TLS)
# COMPANY_PORT=7050    →  https://10.45.30.145:7050  (Company dashboard)
# PROVIDER_PORT=7060   →  https://10.45.30.145:7060  (Provider portal)
# LANDING_PORT=7070    →  https://10.45.30.145:7070  (Landing / booking)
# BACKEND_PORT=7005    →  https://10.45.30.145:7005  (REST API)
# PROMETHEUS_PORT=7083 →  https://10.45.30.145:7083  (Prometheus UI)
# GRAFANA_PORT=7085    →  https://10.45.30.145:7085  (Grafana dashboards)

# Full base URL baked into frontend bundles at build time — must be HTTPS
# API_EXTERNAL_URL=https://10.45.30.145:7005/api/v1

# Grafana public root URL — must match the HTTPS address the browser uses
# GF_SERVER_ROOT_URL=https://10.45.30.145:7085

# CORS: allow all three HTTPS frontend origins to call the API
# ZIYARA_CORS_ALLOWED_ORIGINS=https://10.45.30.145:7050,https://10.45.30.145:7060,https://10.45.30.145:7070

# Landing page "sign in" CTA links (override only if ports/IP differ from above)
# COMPANY_URL=https://10.45.30.145:7050
# PROVIDER_URL=https://10.45.30.145:7060

# ══════════════════════════════════════════════════════════════
# DOMAIN MODE — docker compose --profile portmode up -d --build
#
# Uses Nginx Proxy Manager (NPM) for automatic Let's Encrypt TLS.
# No self-signed certs. No /etc/hosts. Works from any browser.
#
# Full migration guide: docs/DOMAIN_MIGRATION.md
#
# BEFORE FIRST RUN:
#   1. Create DNS A records for all subdomains → server public IP
#   2. Change NPM port bindings in docker-compose.yml: 7080→80, 7082→443
#   3. Uncomment and fill the lines below, then: cp .env.example .env
#   4. docker compose --profile portmode up -d --build
#   5. Open NPM Admin UI (http://localhost:7081 via SSH tunnel)
#   6. Update proxy host domains from *.ziyara.local → your real domains
#   7. Issue Let's Encrypt certificates per proxy host in the NPM UI
#
# Architecture (all HTTPS on port 443 via NPM):
#   app.yourdomain.com          → company-portmode:80   (Company dashboard)
#   portal.yourdomain.com       → provider-portmode:80  (Provider portal)
#   www.yourdomain.com          → landing-portmode:80   (Landing / booking)
#   api.yourdomain.com          → backend:8080          (REST API + Swagger)
#   grafana.yourdomain.com      → grafana:3000          (Grafana dashboards)
#   prometheus.yourdomain.com   → prometheus:9090       (Prometheus metrics)
#   pgadmin.yourdomain.com      → pgadmin:80            (DB admin UI)
#
# Note: each frontend's nginx already proxies /api/ → backend internally,
# so API calls from app./portal./www. work without a separate api. subdomain.
# The api. host is for mobile apps, Swagger UI, and direct API access.
# ══════════════════════════════════════════════════════════════

# NPM Admin UI credentials (change immediately after first login)
# NPM_ADMIN_EMAIL=admin@yourdomain.com
# NPM_ADMIN_PASS=change-me-strong-password

# CORS: allow all three frontend origins to call the API
# ZIYARA_CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://portal.yourdomain.com,https://www.yourdomain.com

# Landing page "Sign In" / "Partner Portal" CTA links
# PORTMODE_HOST=app.yourdomain.com

# Security hardening — enable once HTTPS is confirmed working
# ZIYARA_SECURITY_HSTS_ENABLED=true
# JWT_COOKIE_SECURE=true
# ZIYARA_SECURITY_MFA_REQUIRED_ROLES=SUPER_ADMIN,CEO,FINANCE_MANAGER
