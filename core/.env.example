# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED. Generate: openssl rand -base64 64
JWT_SECRET=change_me_in_production

# Token TTL in milliseconds (default: 24h access, 7d refresh)
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Cookie settings (override in prod: secure=true, same-site=Strict)
JWT_COOKIE_ENABLED=true
JWT_ACCESS_COOKIE_NAME=ziyara_access
JWT_REFRESH_COOKIE_NAME=ziyara_refresh
JWT_COOKIE_SAME_SITE=Lax
JWT_COOKIE_SECURE=false
JWT_ALSO_RETURN_TOKEN_IN_BODY=true

# ── PII Encryption ────────────────────────────────────────────────────────────
# REQUIRED in production. Generate: openssl rand -base64 32
# Leave empty in dev to disable MFA secret encryption (insecure).
ZIYARA_PII_ENCRYPTION_KEY_BASE64=

# ── Database ──────────────────────────────────────────────────────────────────
# When running via docker-compose the app service overrides these automatically.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ziyarah
SPRING_DATASOURCE_USERNAME=ziyarah_user
SPRING_DATASOURCE_PASSWORD=ziyarah_password

# ── Redis ─────────────────────────────────────────────────────────────────────
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# ── SMTP / Email ──────────────────────────────────────────────────────────────
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS_ENABLE=false

# Enable email sending (password reset, OTP, notifications)
APP_NOTIFICATIONS_EMAIL_ENABLED=false
APP_NOTIFICATIONS_EMAIL_FROM=no-reply@ziyara.local
APP_PUBLIC_LANDING_BASE_URL=http://localhost:3000
APP_PROVIDER_APPROVER_RECIPIENTS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave empty to allow localhost defaults.
ZIYARA_CORS_ALLOWED_ORIGINS=

# ── Security ──────────────────────────────────────────────────────────────────
# Roles that require TOTP enrollment before login (comma-separated UserRole names)
# Production example: SUPER_ADMIN,CEO,FINANCE_MANAGER,GENERAL_MANAGER
ZIYARA_SECURITY_MFA_REQUIRED_ROLES=

# Password strength (0=off, 3=recommended in prod)
ZIYARA_PASSWORD_MIN_ZXCVBN_SCORE=0

# Row-Level Security (requires Flyway V13 policies; true in prod)
ZIYARA_RLS_ENABLED=false

# ── Rate Limiting ────────────────────────────────────────────────────────────
ZIYARA_RATE_LIMIT_LOGIN_ENABLED=true
ZIYARA_RATE_LIMIT_LOGIN_MAX_PER_MINUTE=40
ZIYARA_RATE_LIMIT_LOGIN_REDIS_ENABLED=false

# ── Payment Gateway ──────────────────────────────────────────────────────────
PAYMENT_GATEWAY_ENABLED=true
PAYMENT_GATEWAY_PROVIDER=stub
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_BASE_URL=https://api.stripe.com
PAYMENT_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature

# ── Media Storage ────────────────────────────────────────────────────────────
# local (default) or s3
APP_MEDIA_STORAGE_BACKEND=local
APP_MEDIA_STORAGE_ROOT=./data/media
APP_MEDIA_PUBLIC_BASE_URL=
APP_MEDIA_S3_BUCKET=
APP_MEDIA_S3_REGION=us-east-1

# ── FX Rates Refresh ─────────────────────────────────────────────────────────
ZIYARA_FX_REFRESH_ENABLED=false
ZIYARA_FX_REFRESH_API_KEY=
ZIYARA_FX_REFRESH_BASE_CURRENCY=USD
ZIYARA_FX_REFRESH_TARGET_CURRENCIES=EUR,SAR,GBP,AED

# ── Data Retention / GDPR ───────────────────────────────────────────────────
ZIYARA_DATA_RETENTION_ENABLED=false
ZIYARA_DATA_RETENTION_CRON=0 0 4 * * SUN

# ── Kafka (optional) ─────────────────────────────────────────────────────────
ZIYARA_NOTIFICATIONS_KAFKA_ENABLED=false

# ── Observability ────────────────────────────────────────────────────────────
MANAGEMENT_PORT=8081
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.1
MANAGEMENT_OTLP_TRACING_ENDPOINT=
MANAGEMENT_HEALTH_MAIL_ENABLED=false

# ── Reporting ────────────────────────────────────────────────────────────────
ZIYARA_REPORTING_MV_REFRESH_ENABLED=false
